# ============================================
# 🔧 BIBLIAQUIZ - Variables de Entorno
# ============================================
# Copia este archivo como .env y configura tus valores
# NUNCA subas el archivo .env a Git (está en .gitignore)

# ============================================
# 📦 MONGODB - Base de datos
# ============================================
# Para desarrollo local:
# MONGODB_URI=mongodb://localhost:27017/bibliaquiz
#
# Para producción (MongoDB Atlas):
# 1. Crear cuenta gratis en https://cloud.mongodb.com
# 2. Crear cluster gratuito M0
# 3. Database Access > Add Database User
# 4. Network Access > Add IP Address (0.0.0.0/0 para producción)
# 5. Connect > Drivers > Copiar connection string
MONGODB_URI=mongodb://localhost:27017/bibliaquiz

# ============================================
# 🌐 SERVIDOR
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# 🔐 JWT - Autenticación
# ============================================
# IMPORTANTE: En producción usar una clave de mínimo 32 caracteres
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTA_CLAVE_EN_PRODUCCION_MINIMO_32_CARACTERES

# ============================================
# 🔒 CORS - Dominios permitidos
# ============================================
# Desarrollo:
CORS_ORIGIN=http://localhost:8080
#
# Producción (ejemplos):
# CORS_ORIGIN=https://bibliaquiz.vercel.app
# CORS_ORIGIN=https://tu-dominio.com

